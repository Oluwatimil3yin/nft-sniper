# NFT Rarity Sniper - Environment Variables
# Copy this to .env and fill in your keys

# === Alchemy (MANDATORY for fast reveal scraping + mint watching) ===
# Get at https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# WebSocket URL (optional, constructed from key in code)
# ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# === OpenSea (for collection stats, floor price, listings) ===
# Get key at https://docs.opensea.io/reference/api-overview
OPENSEA_API_KEY=your_opensea_api_key_here

# === Telegram Alerts (for watcher) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # e.g. 123456789 or @channelname

# === Optional: IPFS gateways (comma separated for fallbacks) ===
IPFS_GATEWAYS=https://ipfs.io/ipfs/,https://cloudflare-ipfs.com/ipfs/,https://gateway.pinata.cloud/ipfs/

# Note: For true pre-OpenSea sniping, Alchemy is key for fast mint detection + metadata.
